<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jarvis – Testverbindung"
            android:textSize="22sp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sprich mit Jarvis oder tippe eine Nachricht."
            android:textSize="13sp"
            android:paddingBottom="16dp" />

        <EditText
            android:id="@+id/serverUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Server-URL (z. B. https://...ngrok-free.dev)"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/accessKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Zugangsschluessel"
            android:inputType="text"
            android:paddingTop="8dp" />

        <EditText
            android:id="@+id/messageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nachricht an Jarvis"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:paddingTop="8dp" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Text senden"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/talkButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎤 Sprechen"
            android:textSize="18sp"
            android:layout_marginTop="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp" />

        <Button
            android:id="@+id/cameraButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 Zeigen / Scannen"
            android:textSize="18sp"
            android:layout_marginTop="8dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/answerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:textSize="16sp"
            android:textIsSelectable="true"
            android:text="" />
    </LinearLayout>
</ScrollView>
