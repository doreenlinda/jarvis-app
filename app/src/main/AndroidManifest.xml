<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Fuer den "Hey Jarvis"-Hintergrunddienst: dauerhafter Dienst mit
         Mikrofon-Typ (ab Android 14 Pflicht) + sichtbare Benachrichtigung. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:label="Jarvis"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.DayNight">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Der "Hey Jarvis"-Lausch-Dienst: laeuft dauerhaft im Hintergrund
             mit Mikrofon, sichtbar ueber eine Benachrichtigung. -->
        <service
            android:name=".WakeWordService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Stellt der System-Kamera eine sichere Ziel-Datei fuer das Foto
             bereit (volle Aufloesung statt Mini-Vorschaubild). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.jarvis.app.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
